{
  "schema": 1,
  "project": "mahusay",
  "repo": "https://github.com/anthony-celeres/mahusay.git",
  "updated": "2026-07-19",
  "ownership": "external-reference",
  "ladder": "linear-cumulative",
  "base_stack": {
    "framework": "next@16",
    "runtime": "react@19",
    "language": "typescript-strict",
    "styling": "tailwindcss@4",
    "rendering": "ssr-rsc"
  },
  "capabilities": {
    "base":              { "label": "Next.js 16 boilerplate",       "toggle": "build", "summary": "App Router, RSC, TypeScript, Tailwind v4, ESLint." },
    "theming":           { "label": "Adaptive theming",             "toggle": "build", "summary": "Dark / light / system, no hydration flash." },
    "supabase-auth":     { "label": "Supabase auth (SSR)",          "toggle": "build", "summary": "Cookie-based server sessions, email + password, page-guarded dashboard." },
    "route-protection":  { "label": "Edge route protection",        "toggle": "build", "summary": "proxy.ts session refresh + path auth guard + ?next= return flow." },
    "google-oauth":      { "label": "Google OAuth (PKCE)",          "toggle": "build", "summary": "PKCE flow with an /auth/callback route handler." },
    "rbac":              { "label": "Role-based access control",    "toggle": "build", "summary": "Protected admin panel + Postgres RLS." },
    "pwa":               { "label": "Installable PWA",              "toggle": "build", "summary": "Manifest, installable, offline fallback, auth-aware SW caching." },
    "firebase-services": { "label": "Optional Firebase services",   "toggle": "env",   "summary": "Analytics, FCM, Remote Config, Performance — opt-in via env flags, no-op when unset." }
  },
  "tiers": [
    {
      "tier": 1,
      "tag": "v1.0.0",
      "branch": "stage/v1",
      "adds": "base",
      "requires": null,
      "provides": ["base"],
      "new_dependencies": ["next", "react", "react-dom", "tailwindcss"],
      "requires_env": []
    },
    {
      "tier": 2,
      "tag": "v2.0.0",
      "branch": "stage/v2",
      "adds": "theming",
      "requires": "v1.0.0",
      "provides": ["base", "theming"],
      "new_dependencies": ["next-themes"],
      "requires_env": []
    },
    {
      "tier": 3,
      "tag": "v3.0.0",
      "branch": "stage/v3",
      "adds": "supabase-auth",
      "requires": "v2.0.0",
      "provides": ["base", "theming", "supabase-auth"],
      "new_dependencies": ["@supabase/ssr", "@supabase/supabase-js"],
      "requires_env": ["NEXT_PUBLIC_SUPABASE_URL", "NEXT_PUBLIC_SUPABASE_ANON_KEY", "NEXT_PUBLIC_SITE_URL"]
    },
    {
      "tier": 4,
      "tag": "v4.0.0",
      "branch": "stage/v4",
      "adds": "route-protection",
      "requires": "v3.0.0",
      "provides": ["base", "theming", "supabase-auth", "route-protection"],
      "new_dependencies": [],
      "requires_env": []
    },
    {
      "tier": 5,
      "tag": "v5.0.0",
      "branch": "stage/v5",
      "adds": "google-oauth",
      "requires": "v4.0.0",
      "provides": ["base", "theming", "supabase-auth", "route-protection", "google-oauth"],
      "new_dependencies": [],
      "requires_env": [],
      "notes": "Google client id/secret are configured in the Supabase dashboard, not in app env."
    },
    {
      "tier": 6,
      "tag": "v6.0.0",
      "branch": "stage/v6",
      "adds": "rbac",
      "requires": "v5.0.0",
      "provides": ["base", "theming", "supabase-auth", "route-protection", "google-oauth", "rbac"],
      "new_dependencies": [],
      "requires_env": []
    },
    {
      "tier": 7,
      "tag": "v7.0.0",
      "branch": "stage/v7",
      "adds": "pwa",
      "requires": "v6.0.0",
      "provides": ["base", "theming", "supabase-auth", "route-protection", "google-oauth", "rbac", "pwa"],
      "new_dependencies": [],
      "requires_env": []
    },
    {
      "tier": 8,
      "tag": "v8.0.0",
      "branch": "stage/v8",
      "adds": "firebase-services",
      "requires": "v7.0.0",
      "provides": ["base", "theming", "supabase-auth", "route-protection", "google-oauth", "rbac", "pwa", "firebase-services"],
      "new_dependencies": ["firebase"],
      "requires_env": [
        "NEXT_PUBLIC_FIREBASE_API_KEY",
        "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "NEXT_PUBLIC_FIREBASE_PROJECT_ID",
        "NEXT_PUBLIC_FIREBASE_APP_ID"
      ],
      "notes": "firebase-services is present but disabled by default; each service is gated behind a NEXT_PUBLIC_FIREBASE_ENABLE_* flag."
    }
  ]
}
