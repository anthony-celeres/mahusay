# Supabase Configuration
# ----------------------
# Retrieve these values from your Supabase Dashboard: Settings -> API

# The URL of your Supabase project (e.g., https://xyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# The public API key (Anon Key) for your Supabase project
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# The root URL of your local or production server
# (used as the redirect base for confirmation emails and OAuth callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Firebase (OPTIONAL) — complementary services, all opt-in
# -------------------------------------------------------
# Firebase here does NOT replace Supabase (which stays your auth + database).
# It only adds complementary client-side services. Leave everything blank to
# keep Firebase fully disabled (all getters become no-ops).
#
# 1) Core config — from Firebase Console -> Project settings -> Your apps (Web).
#    Fill these to make Firebase available; individual services still need their
#    enable flag below.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# 2) Per-service toggles — set to "true" to enable (default: off)
NEXT_PUBLIC_FIREBASE_ENABLE_ANALYTICS=false
NEXT_PUBLIC_FIREBASE_ENABLE_MESSAGING=false
NEXT_PUBLIC_FIREBASE_ENABLE_REMOTE_CONFIG=false
NEXT_PUBLIC_FIREBASE_ENABLE_PERFORMANCE=false

# 3) Cloud Messaging (FCM) only — Web Push certificate key pair
#    (Firebase Console -> Project settings -> Cloud Messaging -> Web configuration).
#    Background delivery also needs a firebase-messaging-sw.js service worker.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
