# Supabase Configuration
# ----------------------
# Retrieve these values from your Supabase Dashboard: Settings -> API

# The URL of your Supabase project (e.g., https://xyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# The public API key (Anon Key) for your Supabase project
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# The root URL of your local or production server
# (used as the redirect base for confirmation emails and OAuth callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
